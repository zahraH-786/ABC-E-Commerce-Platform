@model IEnumerable<ABC_ECOMMERCE_POE.Models.CartItem>

@{
    ViewData["Title"] = "My Cart";
}

<h1 class="mb-4">My Cart</h1>
<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (!Model.Any())
{
    <p class="text-muted">@ViewBag.Message</p>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Product</th>
                <th>Image</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                        {
                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" width="80" height="80" style="object-fit: cover; border-radius: 6px;" />
                        }
                        else
                        {
                            <span class="text-muted">No Image</span>
                        }
                    </td>
                    <td>
                        <form asp-action="UpdateQuantity" method="post" style="display:inline;">
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control d-inline w-50" onchange="this.form.submit()" />
                        </form>
                    </td>
                    <td>R @item.Product?.Price.ToString("0.00")</td>
                    <td>R @(item.Product?.Price * item.Quantity)</td>
                    <td>
                        <a asp-action="RemoveFromCart" asp-route-id="@item.CartItemId" class="btn btn-danger btn-sm">
                            Remove
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-end mt-3">
        <h5>
            <strong>Total Amount: </strong>
            R @Model.Sum(i => i.Product.Price * i.Quantity).ToString("0.00")
        </h5>
    </div>

    <div class="text-end mt-4">
        <form asp-action="Checkout" method="post">
            <button type="submit" class="btn btn-success btn-lg">Proceed to Checkout</button>
        </form>
    </div>
}
